modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mockup Server"

[[workflows.workflow]]
name = "Backend Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd server && npx prisma db push --skip-generate && npx prisma generate --no-hints && npx tsx src/index.ts"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && ../node_modules/.bin/vite --port 5000 --host 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Mockup Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/mockup-sandbox && PORT=8080 BASE_PATH=/__mockup/ npm run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ENCRYPTION_KEY = "81a2247c98b3a08a8d452f0fef1d4fef84ee30711dbce6a3fc62cb4304382879"
OAUTH_STATE_SECRET = "b26670e115eb7e8bb4638f7eb607d1ba0b8f7d7be998f083a470183a304105c1"

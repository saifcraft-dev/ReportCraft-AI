# ============================================================
# ReportCraft AI — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://user:password@host:5432/reportcraft?sslmode=require"

# --- Clerk Authentication ---
CLERK_SECRET_KEY="sk_live_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# --- AI Providers ---
OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"            # Default: gpt-4o
ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"   # Default

# --- OAuth Connectors ---
OAUTH_STATE_SECRET="replace-with-32-char-random-secret"
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY="replace-with-64-char-hex-string-generated-by-openssl-rand-hex-32"

GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

META_APP_ID="..."
META_APP_SECRET="..."

# --- LemonSqueezy Billing ---
LEMON_SQUEEZY_API_KEY="..."
LEMON_SQUEEZY_WEBHOOK_SECRET="..."
LEMON_SQUEEZY_STORE_ID="..."
LS_STARTER_VARIANT_ID="..."
LS_AGENCY_VARIANT_ID="..."
LS_AGENCY_PRO_VARIANT_ID="..."

# --- Email (Resend) ---
RESEND_API_KEY="re_..."
RESEND_WEBHOOK_SECRET="whsec_..."   # From Resend webhook settings (svix-based)

# --- Cloudinary (Logo Storage) ---
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# --- URLs ---
# SERVER_URL="https://your-backend.railway.app"
# FRONTEND_URL="https://your-frontend.vercel.app"
